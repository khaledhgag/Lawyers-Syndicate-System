# ------------------------------------------------------------------
# SPA (React Router / BrowserRouter) support for Apache shared hosting
# Serves index.html for any route that is not a real file or directory,
# so deep links like /admin, /admin/login, /books reload correctly.
# ------------------------------------------------------------------

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # If the request maps to an existing file or directory, serve it as-is
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Otherwise, hand the route to the SPA
  RewriteRule ^ index.html [L]
</IfModule>

# Fallback if mod_rewrite is unavailable: send 404s to the SPA entry point
ErrorDocument 404 /index.html

# ------------------------------------------------------------------
# Compression
# ------------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript \
    application/javascript application/json application/xml image/svg+xml
</IfModule>

# ------------------------------------------------------------------
# Caching — hashed assets are immutable; never cache index.html
# ------------------------------------------------------------------
<IfModule mod_headers.c>
  <FilesMatch "\.(?:js|css|woff2?|ttf|eot|otf|jpg|jpeg|png|gif|webp|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "(?:index\.html|\.htaccess)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>

# Correct MIME type for ES modules (some Apache configs miss .mjs)
<IfModule mod_mime.c>
  AddType application/javascript .mjs
  AddType image/svg+xml .svg
</IfModule>
